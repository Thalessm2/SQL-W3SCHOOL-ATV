####EX15
SELECT OrderID AS 'Pedido',
COUNT(DISTINCT ProductID) AS 'Numero de Produtos de Diferentes'
FROM OrderDetails
GROUP BY OrderID
ORDER BY 'Numero de Produtos de Diferentes' 
LIMIT 15;

####EX16
SELECT ShipperName AS 'Nome do remetente',
COUNT(ShipperID) AS 'Numero de Transportadoras'
FROM Shippers
GROUP BY ShipperName
ORDER BY 'Numero de Transportadoras'
