####EX27
SELECT SupplierID, COUNT(ProductID) AS TotalProdutos
FROM Products
GROUP BY SupplierID
HAVING COUNT(ProductID) < 5;

####EX28
SELECT COUNT(*) AS QtdeCategorias, TotalProdutos
FROM (
    SELECT CategoryID, COUNT(ProductID) AS TotalProdutos
    FROM Products
    GROUP BY CategoryID
) AS Contagem
GROUP BY TotalProdutos
HAVING COUNT(*) > 1;

####EX29
SELECT YEAR(BirthDate) AS AnoNascimento, COUNT(EmployeeID) AS TotalFuncionarios
FROM Employees
GROUP BY YEAR(BirthDate)
HAVING COUNT(EmployeeID) > 1;

####EX30
SELECT C.Country, COUNT(DISTINCT O.ShipperID) AS TotalShippers
FROM Orders O
JOIN Customers C ON O.CustomerID = C.CustomerID
GROUP BY C.Country
HAVING COUNT(DISTINCT O.ShipperID) > 1;

