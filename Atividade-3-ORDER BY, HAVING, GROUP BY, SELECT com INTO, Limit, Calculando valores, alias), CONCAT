####EX1
SELECT CONCAT (ProductName,'  ',Price) AS 'Nome e preco',
Price, Price*2 AS 'Dobro preco'
FROM Products 
LIMIT 10;

####EX2
SELECT 
    ProductName AS 'Nome do produto',
    Price AS 'Valor do produto',
    CONCAT('O produto ', ProductName, ' custa ', Price, ' euros') AS 'Nome e Valor '
FROM Products
ORDER BY Price ASC
LIMIT 5;

####EX3
SELECT OrderDetailID AS 'Detalhe do pedido',Quantity AS 'Quantidade',
(Quantity * 10) AS 'ValorTotal',
CONCAT('A encomenda ', OrderDetailID, 
           ' tem valor total de ', (Quantity * 10), ' euros') AS 'Nome e Valor' 
FROM OrderDetails
ORDER BY OrderDetailID
LIMIT 15;

####EX4
SELECT EmployeeID AS 'Funcionario',FirstName AS 'Primeiro nome',LastName AS 'Segundo nome',
CONCAT(FirstName, ' ', LastName, ' - Funcionario Senai') AS 'Nome Completo'
FROM Employees
ORDER BY EmployeeID ASC
LIMIT 3;

####EX5
SELECT ProductName AS 'Nome do produto',Price AS 'Preco',(Price * 0.85) AS 'Preco Com Desconto',
CONCAT('O produto ', ProductName, 
           ' custa ', Price, ' euros. ',
           'Com desconto de 15%: ', (Price * 0.85), ' euros') AS Descricao
FROM Products
ORDER BY Price 
LIMIT 8;

####EX6
SELECT CustomerName AS 'Nome do Cliente' ,City 'Cidade',
CONCAT(CustomerName, ' - ', City) AS 'Cliente Cidade'
FROM Customers
ORDER BY CustomerName
LIMIT 12

####EX7
SELECT  OrderDetailID AS 'Detalhe do pedido',Quantity AS 'Quantidade',(100 - Quantity) AS 'Diferenca do stock',
CONCAT('A encomenda ', OrderDetailID, 
           ' possui ', Quantity, ' unidades. ',
           'Faltam ', (100 - Quantity), ' para atingir o stock ideal.') AS 'Descricao'
FROM OrderDetails
ORDER BY OrderDetailID
LIMIT 20;

####EX8
SELECT CategoryName AS 'Nome da categoria', Description AS 'Descricao',
CONCAT(CategoryName, ' - ', Description) AS 'Categoria descricao'
FROM Categories
ORDER BY CategoryName
LIMIT 5;

####EX9
SELECT SupplierName AS 'Nome do fornecedor',ProductName AS 'Nome do produto',Price 'preco',(Price * 50) AS 'Custo 50 Unidades',
CONCAT('Fornecedor ', SupplierName, 
' vende o produto ', ProductName, 
' e 50 unidades custariam ', (Price * 50), ' euros') AS Detalhes
FROM Suppliers s
JOIN Products p ON s.SupplierID = p.SupplierID
ORDER BY s.SupplierName ASC
LIMIT 10;

####EX10
SELECT CustomerName AS 'Nome do cliente',Address AS 'Endereco',City AS 'cidade',PostalCode AS 'Codigo postal',
CONCAT(Address, ' - ', City, ' - ', PostalCode) AS 'Morada Completa',
(LENGTH(Address) + LENGTH(City) + LENGTH(PostalCode)) AS 'TamanhoMorada'
FROM Customers
ORDER BY CustomerName ASC
LIMIT 25;
 
####EX11
SELECT City AS 'Cidade',
COUNT(CustomerID) AS 'Numero de Clientes'
FROM Customers
GROUP BY City
ORDER BY 'Numero de Clientes' DESC 
LIMIT 5;

####EX12 
SELECT CategoryID AS 'categoria do produto',
COUNT(ProductID) AS 'Numero de Produtos'
FROM Products
GROUP BY CategoryID
ORDER BY 'Numero de Produtos' 
LIMIT 3;

####13
SELECT EmployeeID AS 'funcionario',
COUNT(OrderID) AS 'Numero de Encomendas'
FROM Orders
GROUP BY EmployeeID
ORDER BY 'Numero de Encomendas'
LIMIT 5;

####EX14 
SELECT Country AS 'Pais',
COUNT(SupplierID) AS 'Numero de Fornecedores'
FROM Suppliers
GROUP BY Country
ORDER BY 'Numero de Fornecedores' DESC
