####EX47
CREATE TABLE ContactosFornecedores AS
SELECT 
CONCAT(SupplierName, ' - ', ContactName) AS InfoFornecedor
FROM Suppliers
LIMIT 10;

####EX48
SELECT EmployeeID, COUNT(OrderID) AS TotalEncomendas
FROM Orders
GROUP BY EmployeeID
HAVING COUNT(OrderID) * 2 > 50;

####EX49
SELECT TOP 2
ShipperID, COUNT(OrderID) AS TotalEncomendas
INTO ResumoTransportes
FROM Orders
GROUP BY ShipperID
ORDER BY TotalEncomendas DESC;

####EX50
SELECT TOP 3
CONCAT(e.FirstName, ' ', e.LastName) AS NomeCompleto,
COUNT(o.OrderID) AS TotalEncomendas
INTO RelatorioFinal
FROM Employees e
JOIN Orders o ON e.EmployeeID = o.EmployeeID
GROUP BY e.EmployeeID, e.FirstName, e.LastName
HAVING COUNT(o.OrderID) > 5
ORDER BY TotalEncomendas DESC;
