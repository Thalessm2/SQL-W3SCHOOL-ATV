####EX25
SELECT OrderID,
COUNT(DISTINCT ProductID) AS NumeroProdutosDistintos
FROM OrderDetails
GROUP BY OrderID
HAVING COUNT(DISTINCT ProductID) > 3
ORDER BY NumeroProdutosDistintos DESC;

####EX26
SELECT City, COUNT(CustomerID) AS TotalClientes
FROM Customers
GROUP BY City
